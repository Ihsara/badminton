# Copy to .env and fill in. The .env file is gitignored (never committed).

# ── Web server (deployment) ────────────────────────────────────────────────
# Shared password that protects the web edit actions (Excel upload, nickname
# edits). Leave EMPTY to run a read-only site. Share it only with editors.
BADMINTON_EDIT_PASSWORD=
# Max uploaded workbook size in bytes (default 8 MiB).
BADMINTON_MAX_UPLOAD_BYTES=8388608

# ── Scraper (only needed for `badminton discover` / `build`) ───────────────
TOURNAMENTSOFTWARE_USERNAME=
TOURNAMENTSOFTWARE_PASSWORD=
TOURNAMENTSOFTWARE_BASE_URL=https://badmintonfinland.tournamentsoftware.com
